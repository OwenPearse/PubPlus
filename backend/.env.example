# Django / runtime
DJANGO_ENV=local
DJANGO_SECRET_KEY=replace-with-django-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3010,http://localhost:3000,http://localhost:8081,http://127.0.0.1:8081,http://localhost:8082,http://127.0.0.1:8082
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3010,http://localhost:3000
TIME_ZONE=UTC

# Database
DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.<project-ref>
DB_PASSWORD=your-raw-db-password-here

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-if-needed

# JWT / auth verification
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ALGORITHM=RS256

# Storage / media placeholders
SUPABASE_STORAGE_BUCKET_VENUES=venues
MEDIA_URL=/media/

# Internal / admin protection placeholders
INTERNAL_ADMIN_ENABLED=false
INTERNAL_ADMIN_TOKEN=replace-with-internal-admin-token
INTERNAL_ADMIN_ALLOWED_IPS=127.0.0.1
# Comma-separated Supabase auth user UUIDs (JWT sub) for internal API + web-portal
PUBPLUS_INTERNAL_ADMIN_SUBJECTS=

# Optional local overrides
LOCAL_SETTINGS_MODULE=
